# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-prod
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Postgres ---
POSTGRES_DB=neyla
POSTGRES_USER=neyla
POSTGRES_PASSWORD=neyla
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# prefer (dev, fallback non-TLS) | require (Postgres managé, ex. DO App Platform)
POSTGRES_SSLMODE=prefer

# --- Redis ---
# Local : redis://...  | Managé (DO App Platform) : rediss://... (TLS auto-géré)
REDIS_URL=redis://redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
API_URL_INTERNAL=http://api:8000
FRONTEND_URL=http://localhost:3000

# --- Email (dev = console backend, prod = SMTP à configurer) ---
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=no-reply@neyla.tv

# --- Streamers ---
# Nombre max d'approbations de candidatures streamer par jour (maîtrise des coûts).
STREAMER_DAILY_APPROVAL_QUOTA=100

# --- Cloudflare Stream ---
# Laisser CLOUDFLARE_API_TOKEN vide en dev pour activer le mode FAKE
# (URLs rtmps://fake.local, pas d'appel réseau, idéal pour les tests).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_WEBHOOK_SECRET=dev-webhook-secret

# --- Production seulement ---
# Sentry (laisser vide en dev) :
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev
SENTRY_TRACES_SAMPLE_RATE=0.1

# Backups Postgres → DigitalOcean Spaces (S3-compatible) :
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BACKUPS_BUCKET=neyla-backups
SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
